{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LEVI-Tempest/candle/docs/signal.schema.json",
  "title": "Candle Signal Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol",
    "as_of",
    "source",
    "trend",
    "score",
    "patterns",
    "evidence",
    "counter_evidence",
    "invalid_if"
  ],
  "properties": {
    "symbol": {
      "type": "string",
      "minLength": 1
    },
    "as_of": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "trend": {
      "type": "string",
      "enum": [
        "up",
        "down",
        "range",
        "unknown"
      ]
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "direction",
          "position",
          "strength",
          "risk",
          "price",
          "time"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "bullish",
              "bearish",
              "neutral"
            ]
          },
          "position": {
            "type": "integer",
            "minimum": 0
          },
          "strength": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "risk": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "price": {
            "type": "number"
          },
          "time": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "pattern_type",
          "direction",
          "position",
          "time",
          "price",
          "base_strength",
          "context_score",
          "volume_score",
          "final_score",
          "confidence_level",
          "context_factors",
          "volume_factors",
          "contradiction_factors"
        ]
      }
    },
    "counter_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invalid_if": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
